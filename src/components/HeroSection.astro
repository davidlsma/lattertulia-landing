---
---

<section id="hero" class="relative h-screen flex flex-col justify-start overflow-hidden">

  <!-- Imagen de fondo desktop -->
  <img
    src="assets/images/hero-bg.png"
    alt=""
    aria-hidden="true"
    loading="eager"
    width="1200"
    height="1200"
    class="absolute inset-0 w-full h-full object-cover hidden md:block" style="object-position: right 55%; transform: translateY(0%);"
  />
  <!-- Imagen de fondo mobile -->
  <img
    src="assets/images/hero-mobile.jpg"
    alt=""
    aria-hidden="true"
    loading="eager"
    width="800"
    height="1200"
    class="absolute inset-0 w-full h-full object-cover md:hidden" style="object-position: center center;"
  />

  <!-- Contenido -->
  <div class="relative z-10 max-w-screen-xl mx-auto px-6 md:px-10 lg:px-16 w-full pt-52 pb-16">

    <div class="w-full fade-in text-center md:text-left">

      <!-- Título full width -->
      <p class="label-sm mb-4" style="color: rgba(250,250,248,0.6);">Córdoba, Argentina</p>
      <h1 class="heading-display mb-8 w-full" style="color: #FAFAF8; line-height: 1;">
        <span style="font-size: clamp(2.5rem, 6vw, 6.5rem); display: block;">Café de Especialidad</span>
        <span style="font-size: clamp(1.6rem, 3.2vw, 3.5rem); display: block; margin-top: 0.4rem;">Viennoiserie y Pastelería</span>
      </h1>

      <div class="flex md:block justify-center">
        <a
          href="#carta"
          class="inline-flex items-center gap-3 px-8 py-4 label-sm transition-colors"
          style="background: #1B2A46; color: #FAFAF8;"
          onmouseover="this.style.background='#243656'"
          onmouseout="this.style.background='#1B2A46'"
        >
          Ver más
          <span aria-hidden="true">↗</span>
        </a>
      </div>

    </div>


</div>
</section>

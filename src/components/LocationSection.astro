---
const horarios = [
  { dias: 'Lunes a Sábados', horas: '08:00 — 21:00' },
  { dias: 'Domingos',        horas: '16:00 — 21:00' },
];
---

<section id="ubicacion" class="py-24 md:py-32">
  <div class="max-w-screen-xl mx-auto px-6 md:px-10 lg:px-16">

    <!-- Títulos centrados -->
    <div class="text-center mb-16 fade-in">
      <p class="label-sm text-muted mb-6">Dónde encontrarnos</p>
      <h2 class="heading-xl text-on-surface">
        Visitanos en Córdoba.
      </h2>
    </div>

    <!-- Dos columnas -->
    <div class="grid md:grid-cols-2 gap-12 md:gap-20 items-start">

      <!-- Columna info -->
      <div class="fade-in space-y-8 text-center">

        <div>
          <p class="label-sm text-muted mb-2">Dirección</p>
          <p class="heading-md text-on-surface font-light">
            José Manuel Estrada 284
          </p>
          <p class="body-lg text-muted">Nueva Córdoba, Córdoba, Argentina</p>
        </div>

        <div>
          <p class="label-sm text-muted mb-3">Horarios</p>
          <div class="space-y-2">
            {horarios.map(h => (
              <div class="flex justify-between items-baseline border-b border-surface-high pb-2 max-w-xs mx-auto">
                <span class="body-lg text-on-surface">{h.dias}</span>
                <span class="label-sm text-muted">{h.horas}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="flex gap-4 flex-wrap justify-center">
          <a
            href="https://maps.google.com/?q=José+Manuel+Estrada+284+Nueva+Córdoba+Córdoba+Argentina"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 label-sm transition-colors"
            style="background: #1B2A46; color: #FAFAF8;"
            onmouseover="this.style.background='#243656'"
            onmouseout="this.style.background='#1B2A46'"
          >
            Cómo llegar ↗
          </a>
        </div>

      </div>

      <!-- Columna mapa -->
      <div class="fade-in">
        <div class="w-full bg-surface-low border border-surface-high overflow-hidden" style="aspect-ratio: 4/3;">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3404.9!2d-64.1847!3d-31.4167!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sJos%C3%A9+Manuel+Estrada+284%2C+Nueva+C%C3%B3rdoba%2C+C%C3%B3rdoba!5e0!3m2!1ses!2sar!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa de ubicación de Lattertulia — José Manuel Estrada 284, Nueva Córdoba"
          ></iframe>
        </div>
      </div>

    </div>

  </div>
</section>

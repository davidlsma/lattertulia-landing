---
---

<footer class="py-20" style="background: #1B2A46;">
  <div class="max-w-screen-xl mx-auto px-6 md:px-10 lg:px-16">

    <div class="grid grid-cols-2 gap-10 items-center">

      <!-- Columna izquierda: Logo -->
      <div class="flex justify-center">
        <a href="/" aria-label="Lattertulia — Inicio" class="inline-block">
          <img src="assets/images/logo-1.png" alt="Lattertulia" class="w-full max-w-[220px] h-auto" />
        </a>
      </div>

      <!-- Columna derecha -->
      <div class="text-center">
        <p style="line-height: 1; display: flex; align-items: flex-end; justify-content: center; gap: 2px;">
          <span style="color: #FAFAF8; font-family: 'Inter', Arial, sans-serif; font-size: clamp(2.5rem, 5vw, 5rem); font-weight: 600; display: inline-block;">A</span>
          <span style="width: 10px; height: 10px; background: #FAFAF8; border-radius: 50%; display: inline-block; margin-bottom: 6px; flex-shrink: 0;"></span>
        </p>
        <p class="label-sm mt-3">
          <span style="color: rgba(250,250,248,0.4);">Diseñado por </span><span style="color: rgba(250,250,248,0.8);">Andescode</span>
        </p>
      </div>

    </div>

    <div class="mt-12 pt-6 text-center" style="border-top: 1px solid rgba(250,250,248,0.15);">
      <p class="label-sm" style="color: rgba(250,250,248,0.4);">
        © <span id="footer-year"></span> Lattertulia. Todos los derechos reservados.
      </p>
    </div>

  </div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>

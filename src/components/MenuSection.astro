---
const cards = [
  { img: 'assets/images/carta-1.jpg', alt: 'Pistacho' },
  { img: 'assets/images/carta-2.jpg', alt: 'Roll de jamón y queso' },
  { img: 'assets/images/carta-3.jpg', alt: 'Suavecito' },
  { img: 'assets/images/carta-4.jpg', alt: 'Danesa' },
];
---

<section id="carta" class="py-24 md:py-32 bg-surface-low">
  <div class="max-w-screen-xl mx-auto px-6 md:px-10 lg:px-16">

    <div class="mb-16 fade-in text-center">
      <p class="label-sm text-muted mb-4">Lo que preparamos</p>
      <h2 class="heading-xl text-on-surface">Un vistazo de nuestra carta.</h2>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 fade-in">
      {cards.map(card => (
        <div class="overflow-hidden" style="border-radius: 2px;">
          <img
            src={card.img}
            alt={card.alt}
            class="w-full object-cover"
            style="height: clamp(160px, 30vw, 320px);"
            loading="lazy"
          />
          <p class="text-center text-on-surface mt-3" style="font-family: var(--font-display); font-size: 1.1rem;">{card.alt}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 fade-in flex justify-center">
      <button
        id="btn-ver-carta"
        class="inline-flex items-center gap-3 px-8 py-4 label-sm transition-colors"
        style="background: #1B2A46; color: #FAFAF8;"
        onmouseover="this.style.background='#243656'"
        onmouseout="this.style.background='#1B2A46'"
      >
        Ver opciones
        <span aria-hidden="true">↗</span>
      </button>
    </div>

  </div>
</section>

<!-- Modal carta -->
<div id="carta-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4" style="display: none !important; background: rgba(0,0,0,0.85);">
  <button
    id="close-carta"
    class="absolute top-4 right-6 label-sm"
    style="color: #FAFAF8; font-size: 2rem; line-height: 1; background: none; border: none; cursor: pointer;"
    aria-label="Cerrar"
  >×</button>
  <img
    src="assets/images/carta-menu.png"
    alt="Carta completa"
    class="max-h-screen max-w-full object-contain"
    style="max-height: 90vh; max-width: 90vw;"
  />
</div>

<script>
  const btn = document.getElementById('btn-ver-carta');
  const modal = document.getElementById('carta-modal') as HTMLElement;
  const closeBtn = document.getElementById('close-carta');

  btn?.addEventListener('click', () => {
    modal.style.display = 'flex';
  });

  closeBtn?.addEventListener('click', () => {
    modal.style.display = 'none';
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.style.display = 'none';
  });
</script>

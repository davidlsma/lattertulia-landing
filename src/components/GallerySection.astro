---
const photos = [
  { src: 'assets/images/gallery-1.jpg', alt: 'Lattertulia' },
  { src: 'assets/images/gallery-2.jpg', alt: 'Lattertulia' },
  { src: 'assets/images/gallery-3.jpg', alt: 'Lattertulia' },
  { src: 'assets/images/gallery-4.jpg', alt: 'Lattertulia' },
  { src: 'assets/images/gallery-5.jpg', alt: 'Lattertulia' },
  { src: 'assets/images/gallery-6.jpg', alt: 'Lattertulia' },
  { src: 'assets/images/gallery-7.jpg', alt: 'Lattertulia' },
  { src: 'assets/images/gallery-8.jpg', alt: 'Lattertulia' },
];
---

<section id="galeria" class="py-24 md:py-32 bg-surface-low">
  <div class="max-w-5xl mx-auto px-6 md:px-10 lg:px-16">

    <div class="mb-12 fade-in text-center">
      <p class="label-sm text-muted mb-4">Ambiente y productos</p>
      <h2 class="heading-xl text-on-surface">La experiencia.</h2>
    </div>

    <!-- Fotos + card Instagram en desktop -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 fade-in">
      {photos.slice(0, 4).map((photo) => (
        <div class="overflow-hidden aspect-square">
          <img
            src={photo.src}
            alt={photo.alt}
            loading="lazy"
            width="600"
            height="600"
            class="w-full h-full object-cover transition-all duration-500"
          />
        </div>
      ))}

      <!-- Card Instagram visible solo en desktop (centro de fila 3) -->
      <a
        href="https://instagram.com/lattertulia.cafe"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:flex overflow-hidden aspect-square flex-col items-center justify-center gap-4 transition-opacity hover:opacity-80"
        style="background: #1B2A46;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#FAFAF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        <span class="label-sm" style="color: #FAFAF8;">@lattertulia.cafe</span>
        <span class="label-sm" style="color: rgba(250,250,248,0.5); font-size: 0.7rem;">Ver más ↗</span>
      </a>

      {photos.slice(4).map((photo) => (
        <div class="overflow-hidden aspect-square">
          <img
            src={photo.src}
            alt={photo.alt}
            loading="lazy"
            width="600"
            height="600"
            class="w-full h-full object-cover transition-all duration-500"
          />
        </div>
      ))}
    </div>

    <!-- Botón Instagram visible solo en mobile -->
    <div class="flex justify-center mt-8 fade-in md:hidden">
      <a
        href="https://instagram.com/lattertulia.cafe"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-8 py-4 label-sm transition-colors"
        style="background: #1B2A46; color: #FAFAF8;"
        onmouseover="this.style.background='#243656'"
        onmouseout="this.style.background='#1B2A46'"
      >
        Ver en Instagram
        <span aria-hidden="true">↗</span>
      </a>
    </div>

  </div>
</section>
